<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order Confirmation</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #f4f7fb;
      font-family: Arial, Helvetica, sans-serif;
      color: #333;
      padding: 30px 15px;
    }

    .container {
      max-width: 650px;
      margin: auto;
      background: #ffffff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .header {
      background: linear-gradient(135deg,#2563eb,#4f46e5);
      color: #fff;
      text-align: center;
      padding: 35px 20px;
    }

    .header h1 {
      font-size: 30px;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 15px;
      opacity: .9;
    }

    .content {
      padding: 35px;
    }

    .content h2 {
      margin-bottom: 15px;
      color: #111827;
    }

    .content p {
      line-height: 1.8;
      margin-bottom: 18px;
      color: #4b5563;
      font-size: 15px;
    }

    .order-card {
      margin: 25px 0;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      overflow: hidden;
    }

    .order-card table {
      width: 100%;
      border-collapse: collapse;
    }

    .order-card td {
      padding: 15px 18px;
      border-bottom: 1px solid #e5e7eb;
      font-size: 15px;
    }

    .order-card td:first-child {
      font-weight: bold;
      width: 40%;
      background: #f9fafb;
      color: #374151;
    }

    .price {
      color: #16a34a;
      font-size: 22px;
      font-weight: bold;
    }

    .success-box {
      background: #ecfdf5;
      border-left: 5px solid #10b981;
      padding: 18px;
      border-radius: 8px;
      margin: 30px 0;
    }

    .success-box h3 {
      color: #047857;
      margin-bottom: 8px;
    }

    .button {
      display: inline-block;
      margin-top: 20px;
      background: #2563eb;
      color: #fff !important;
      text-decoration: none;
      padding: 14px 28px;
      border-radius: 6px;
      font-weight: bold;
    }

    .footer {
      background: #f9fafb;
      text-align: center;
      padding: 25px;
      font-size: 13px;
      color: #6b7280;
      border-top: 1px solid #e5e7eb;
    }

    .footer p {
      margin: 5px 0;
    }

    @media(max-width:600px){

      .content{
        padding:25px;
      }

      .header h1{
        font-size:24px;
      }

      .order-card td{
        display:block;
        width:100%;
      }

      .order-card td:first-child{
        border-bottom:none;
      }

    }
  </style>
</head>

<body>

<div class="container">

    <div class="header">
        <h1>🎉 Order Confirmed</h1>
        <p>Thank you for your purchase!</p>
    </div>

    <div class="content">

        <h2>Hello <%= user.name %>,</h2>

        <p>
            Thank you for your order. We're excited to let you know that your
            purchase has been successfully confirmed.
        </p>

        <div class="success-box">
            <h3>✅ Payment Successful</h3>
            <p>
                Your order has been processed successfully. You can now start
                learning immediately.
            </p>
        </div>

        <div class="order-card">

            <table>

                <tr>
                    <td>Order ID</td>
                    <td>#<%= order._id %></td>
                </tr>

                <tr>
                    <td>Course</td>
                    <td><%= order.name %></td>
                </tr>

                <tr>
                    <td>Purchase Date</td>
                    <td><%= order.date %></td>
                </tr>

                <tr>
                    <td>Email</td>
                    <td><%= user.email %></td>
                </tr>

                <tr>
                    <td>Total Paid</td>
                    <td class="price">$<%= order.price %></td>
                </tr>

            </table>

        </div>

        <p>
            Thank you for choosing us. We hope you enjoy your learning journey.
            If you have any questions, simply reply to this email—we're always
            happy to help.
        </p>

        <!-- Replace with your frontend URL -->
        <a href="https://yourwebsite.com/my-courses" class="button">
            View My Courses
        </a>

    </div>

    <div class="footer">

        <p><strong>Your LMS</strong></p>

        <p>
            This email was sent because you made a purchase using
            <%= user.email %>.
        </p>

        <p>
            © <%= new Date().getFullYear() %> Your LMS. All rights reserved.
        </p>

    </div>

</div>

</body>
</html>